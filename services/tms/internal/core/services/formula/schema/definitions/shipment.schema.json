{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://trenova.com/schemas/formula/shipment.schema.json",
    "title": "Shipment",
    "description": "A shipment entity with all fields available for formula calculations",
    "type": "object",
    "version": "1.0.0",
    "x-formula-context": {
        "category": "shipment",
        "entities": [
            "Shipment"
        ],
        "permissions": [
            "formula:read:shipment"
        ]
    },
    "x-data-source": {
        "table": "shipments",
        "entity": "github.com/emoss08/trenova/internal/core/domain/shipment.Shipment",
        "preloads": [
            "Customer",
            "TractorType",
            "TrailerType",
            "Moves.Stops",
            "AdditionalCharges.AccessorialCharge",
            "Commodities.Commodity",
            "Commodities.Commodity.HazardousMaterial"
        ]
    },
    "properties": {
        "proNumber": {
            "description": "The PRO number uniquely identifying the shipment",
            "type": "string",
            "x-source": {
                "field": "pro_number",
                "path": "ProNumber"
            }
        },
        "status": {
            "description": "Current status of the shipment",
            "type": "string",
            "enum": [
                "New",
                "InTransit",
                "Delayed",
                "Completed",
                "Billed",
                "PartiallyAssigned",
                "Assigned",
                "PartiallyCompleted",
                "Cancelled"
            ],
            "x-source": {
                "field": "status",
                "path": "Status"
            }
        },
        "weight": {
            "description": "Total weight of the shipment in pounds",
            "type": [
                "number",
                "null"
            ],
            "minimum": 0,
            "x-source": {
                "field": "weight",
                "path": "Weight",
                "nullable": true,
                "transform": "int64ToFloat64"
            }
        },
        "pieces": {
            "description": "Number of pieces in the shipment",
            "type": [
                "integer",
                "null"
            ],
            "minimum": 0,
            "x-source": {
                "field": "pieces",
                "path": "Pieces",
                "nullable": true
            }
        },
        "temperatureMin": {
            "description": "Minimum required temperature in Fahrenheit",
            "type": [
                "number",
                "null"
            ],
            "x-source": {
                "field": "temperature_min",
                "path": "TemperatureMin",
                "nullable": true,
                "transform": "int16ToFloat64"
            }
        },
        "temperatureMax": {
            "description": "Maximum required temperature in Fahrenheit",
            "type": [
                "number",
                "null"
            ],
            "x-source": {
                "field": "temperature_max",
                "path": "TemperatureMax",
                "nullable": true,
                "transform": "int16ToFloat64"
            }
        },
        "baseRate": {
            "description": "Base rate per unit for freight charge calculation",
            "type": "number",
            "minimum": 0,
            "x-source": {
                "field": "base_rate",
                "path": "BaseRate",
                "transform": "decimalToFloat64"
            }
        },
        "freightChargeAmount": {
            "description": "Calculated freight charge amount in USD",
            "type": "number",
            "minimum": 0,
            "x-source": {
                "field": "freight_charge_amount",
                "path": "FreightChargeAmount",
                "transform": "decimalToFloat64"
            }
        },
        "otherChargeAmount": {
            "description": "Total additional charges in USD",
            "type": "number",
            "minimum": 0,
            "x-source": {
                "field": "other_charge_amount",
                "path": "OtherChargeAmount",
                "transform": "decimalToFloat64"
            }
        },
        "currentTotalCharge": {
            "description": "Current total shipment charge in USD",
            "type": "number",
            "minimum": 0,
            "x-source": {
                "computed": true,
                "function": "computeCurrentTotalCharge"
            }
        },
        "ratingUnit": {
            "description": "Unit value used in rating calculations",
            "type": "integer",
            "minimum": 1,
            "x-source": {
                "field": "rating_unit",
                "path": "RatingUnit"
            }
        },
        "customer": {
            "description": "Customer associated with the shipment",
            "type": "object",
            "x-source": {
                "relation": "Customer"
            },
            "properties": {
                "name": {
                    "description": "Customer company name",
                    "type": "string",
                    "x-source": {
                        "path": "Customer.Name"
                    }
                },
                "code": {
                    "description": "Customer code",
                    "type": "string",
                    "x-source": {
                        "path": "Customer.Code"
                    }
                }
            },
            "required": [
                "name",
                "code"
            ]
        },
        "tractorType": {
            "description": "Equipment type for the tractor",
            "type": [
                "object",
                "null"
            ],
            "x-source": {
                "relation": "TractorType",
                "nullable": true
            },
            "properties": {
                "name": {
                    "description": "Equipment type name",
                    "type": "string",
                    "x-source": {
                        "path": "TractorType.Name"
                    }
                },
                "code": {
                    "description": "Equipment type code",
                    "type": "string",
                    "x-source": {
                        "path": "TractorType.Code"
                    }
                },
                "costPerMile": {
                    "description": "Operating cost per mile in USD",
                    "type": [
                        "number",
                        "null"
                    ],
                    "minimum": 0,
                    "x-source": {
                        "path": "TractorType.CostPerMile",
                        "transform": "decimalToFloat64",
                        "nullable": true
                    }
                }
            }
        },
        "trailerType": {
            "description": "Equipment type for the trailer",
            "type": [
                "object",
                "null"
            ],
            "x-source": {
                "relation": "TrailerType",
                "nullable": true
            },
            "properties": {
                "name": {
                    "description": "Equipment type name",
                    "type": "string",
                    "x-source": {
                        "path": "TrailerType.Name"
                    }
                },
                "code": {
                    "description": "Equipment type code",
                    "type": "string",
                    "x-source": {
                        "path": "TrailerType.Code"
                    }
                },
                "costPerMile": {
                    "description": "Operating cost per mile in USD",
                    "type": [
                        "number",
                        "null"
                    ],
                    "minimum": 0,
                    "x-source": {
                        "path": "TrailerType.CostPerMile",
                        "transform": "decimalToFloat64",
                        "nullable": true
                    }
                }
            }
        },
        "temperatureDifferential": {
            "description": "Difference between maximum and minimum temperature requirements",
            "type": "number",
            "x-source": {
                "computed": true,
                "function": "computeTemperatureDifferential",
                "requires": [
                    "temperatureMin",
                    "temperatureMax"
                ]
            }
        },
        "requiresTemperatureControl": {
            "description": "Whether the shipment requires temperature control",
            "type": "boolean",
            "x-source": {
                "computed": true,
                "function": "computeRequiresTemperatureControl",
                "requires": [
                    "temperatureMin",
                    "temperatureMax"
                ]
            }
        },
        "totalStops": {
            "description": "Total number of stops across all moves",
            "type": "integer",
            "minimum": 0,
            "x-source": {
                "computed": true,
                "function": "computeTotalStops",
                "requires": [
                    "Moves"
                ]
            }
        },
        "totalDistance": {
            "description": "Total distance across all moves",
            "type": "number",
            "minimum": 0,
            "x-source": {
                "computed": true,
                "function": "computeTotalDistance",
                "requires": [
                    "Moves"
                ]
            }
        },
        "totalWeight": {
            "description": "Total shipment weight including commodity fallback",
            "type": "number",
            "minimum": 0,
            "x-source": {
                "computed": true,
                "function": "computeTotalWeight",
                "requires": [
                    "Commodities"
                ]
            }
        },
        "totalPieces": {
            "description": "Total shipment pieces including commodity fallback",
            "type": "integer",
            "minimum": 0,
            "x-source": {
                "computed": true,
                "function": "computeTotalPieces",
                "requires": [
                    "Commodities"
                ]
            }
        },
        "totalLinearFeet": {
            "description": "Total linear feet from shipment commodities",
            "type": "number",
            "minimum": 0,
            "x-source": {
                "computed": true,
                "function": "computeTotalLinearFeet",
                "requires": [
                    "Commodities",
                    "Commodities.Commodity"
                ]
            }
        },
        "hasHazmat": {
            "description": "Whether any shipment commodity is hazardous material",
            "type": "boolean",
            "x-source": {
                "computed": true,
                "function": "computeHasHazmat",
                "requires": [
                    "Commodities",
                    "Commodities.Commodity",
                    "Commodities.Commodity.HazardousMaterial"
                ]
            }
        }
    },
    "required": [
        "proNumber",
        "status",
        "baseRate",
        "freightChargeAmount",
        "otherChargeAmount",
        "ratingUnit",
        "customer"
    ]
}
