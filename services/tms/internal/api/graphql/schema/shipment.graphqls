  axleWeights: [ShipmentAxleWeight!]!
  recommendations: [ShipmentLoadingRecommendation!]!
  stopDividers: [ShipmentStopDivider!]
  aiAnalysis: String
}

input ShipmentRatingDetailInput {
  formulaTemplateId: String!
  formulaTemplateName: String!
  expression: String!
  resolvedVariables: JSON!
  result: Float!
  ratedAt: Int!
}

input ShipmentInput {
  sourceDocumentId: String
  serviceTypeId: ID!
  shipmentTypeId: ID!
  customerId: ID!
  tractorTypeId: ID
  trailerTypeId: ID
  ownerId: ID
  enteredById: ID
  canceledById: ID
  formulaTemplateId: ID!
  consolidationGroupId: ID
  orderId: ID
  status: ShipmentStatus = New
  tenderStatus: ShipmentTenderStatus
  entryMethod: ShipmentEntryMethod = Manual
  proNumber: String
  bol: String
  cancelReason: String
  otherChargeAmount: String = "0"
  freightChargeAmount: String = "0"
  baseRate: String = "0"
  totalChargeAmount: String = "0"
  pieces: Int
  weight: Int
  temperatureMin: Int
  temperatureMax: Int
  actualDeliveryDate: Int
  actualShipDate: Int
  canceledAt: Int
  billingTransferStatus: String
  transferredToBillingAt: Int
  markedReadyToBillAt: Int
  billedAt: Int
  ratingUnit: Int = 1
  fuelSurchargeLocked: Boolean = false
  ratingDetail: ShipmentRatingDetailInput
  version: Int
  moves: [ShipmentMoveInput!] = []
  additionalCharges: [ShipmentAdditionalChargeInput!] = []
  commodities: [ShipmentCommodityInput!] = []
}

input ShipmentMoveInput {
  id: ID
  shipmentId: ID
  status: MoveStatus = New
  loaded: Boolean = true
  sequence: Int = 0
  distance: Float
  distanceSource: String
  distanceProvider: String
  distanceCalculatedAt: Int
  distanceRouteSignature: String
  distanceDataVersion: String
  distanceRoutingType: String
  distanceUnits: String
  distanceMetadata: JSON
  version: Int
  stops: [ShipmentStopInput!] = []
}

input ShipmentStopInput {
  id: ID
  shipmentMoveId: ID
  locationId: ID!
  status: StopStatus = New
  type: StopType = Pickup
  scheduleType: StopScheduleType = Open
  sequence: Int = 0
  pieces: Int
  weight: Int
  scheduledWindowStart: Int = 0
  scheduledWindowEnd: Int
  actualArrival: Int
  actualDeparture: Int
  countLateOverride: Boolean
  countDetentionOverride: Boolean
  addressLine: String
  version: Int
}

input ShipmentAdditionalChargeInput {
  id: ID
  shipmentId: ID
  accessorialChargeId: ID!
  isSystemGenerated: Boolean = false
  method: String = "Flat"
  amount: String = "0"
  unit: Int = 1
  fuelSurchargeProgramId: ID
  version: Int
}

input ShipmentCommodityInput {
  id: ID
  shipmentId: ID
  commodityId: ID!
  pieces: Int = 1
  weight: Int = 0
  version: Int
}

input ShipmentDuplicateInput {
  shipmentId: ID!
  count: Int = 1
  overrideDates: Boolean = false
}

input ShipmentCancelInput {
  cancelReason: String
}

input ShipmentTransferOwnershipInput {
  ownerId: ID!
}

input ShipmentDuplicateBolInput {
  bol: String!
  shipmentId: ID
}

input ShipmentHazmatInput {
  commodityIds: [ID!]!
}

input ShipmentPreviousRatesInput {
  originLocationId: ID!
  destinationLocationId: ID!
  shipmentTypeId: ID!
  serviceTypeId: ID!
  customerId: ID
  excludeShipmentId: ID
}

input ShipmentLoadingCommodityInput {
  commodityId: ID!
  pieces: Int!
  weight: Int!
}

input ShipmentLoadingStopInput {
  sequence: Int!
  locationName: String!
  locationCity: String!
}

input ShipmentLoadingOptimizationInput {
  commodities: [ShipmentLoadingCommodityInput!]!
  equipmentTypeId: ID
  stops: [ShipmentLoadingStopInput!]
}

input ShipmentTransferToBillingInput {
  shipmentId: ID!
  billType: BillType = Invoice
}

input ShipmentBulkTransferToBillingInput {
  shipmentIds: [ID!]!
  billType: BillType = Invoice
}

input ShipmentCommentInput {
  comment: String!
  mentionedUserIds: [ID!] = []
  type: ShipmentCommentType = Internal
  visibility: ShipmentCommentVisibility = Internal
  priority: ShipmentCommentPriority = Normal
}

input ShipmentCommentUpdateInput {
  id: ID!
  comment: String!
  mentionedUserIds: [ID!] = []
  type: ShipmentCommentType = Internal
  visibility: ShipmentCommentVisibility = Internal
  priority: ShipmentCommentPriority = Normal
  version: Int!
}

input ShipmentsInput {
  first: Int = 20
  after: String
  query: String
  fieldFilters: [FieldFilterInput!]
  filterGroups: [FilterGroupInput!]
  sort: [SortFieldInput!]
  expandShipmentDetails: Boolean = false
  status: String
  activityWindowStart: Int
  activityWindowEnd: Int
}

input ShipmentEventsInput {
  shipmentId: ID
  types: [ShipmentEventType!]
  limit: Int
  before: Int
}

input ShipmentAnalyticsInput {
  startDate: Int
  endDate: Int
  limit: Int
  offset: Int
  timezone: String
  windowDays: Int
  include: String
}

extend type Query {
  shipments(input: ShipmentsInput!): ShipmentConnection!
  shipment(id: ID!, expandShipmentDetails: Boolean = false, status: String): Shipment
  unassignedShipments(first: Int = 20, after: String): ShipmentConnection!
  shipmentComments(shipmentId: ID!, first: Int = 20, after: String): ShipmentCommentConnection!
  shipmentCommentCount(shipmentId: ID!): ShipmentCommentCountResponse!
  shipmentUIPolicy: ShipmentUIPolicy!
  shipmentBillingReadiness(shipmentId: ID!): ShipmentBillingReadiness!
  shipmentEvents(input: ShipmentEventsInput!): [ShipmentEvent!]!
  shipmentAnalytics(input: ShipmentAnalyticsInput!): ShipmentAnalytics!
  shipmentPreviousRates(input: ShipmentPreviousRatesInput!): ShipmentPreviousRatesResponse!
}

extend type Mutation {
  createShipment(input: ShipmentInput!): Shipment!
  updateShipment(id: ID!, input: ShipmentInput!): Shipment!
  cancelShipment(id: ID!, input: ShipmentCancelInput): Shipment!
  uncancelShipment(id: ID!): Shipment!
  duplicateShipment(input: ShipmentDuplicateInput!): ShipmentDuplicateResponse!
  transferShipmentOwnership(id: ID!, input: ShipmentTransferOwnershipInput!): Shipment!
  transferShipmentToBilling(input: ShipmentTransferToBillingInput!): BillingQueueItem!
  bulkTransferShipmentsToBilling(input: ShipmentBulkTransferToBillingInput!): ShipmentBulkTransferToBillingResponse!
  calculateShipmentTotals(input: ShipmentInput!): ShipmentTotalsResponse!
  calculateShipmentDistance(input: ShipmentInput!): ShipmentDistanceResponse!
  recalculateShipmentDistance(shipmentId: ID!): ShipmentDistanceResponse!
  checkShipmentDuplicateBol(input: ShipmentDuplicateBolInput!): ShipmentValidationResponse!
  checkShipmentHazmatSegregation(input: ShipmentHazmatInput!): ShipmentValidationResponse!
  calculateShipmentLoadingOptimization(input: ShipmentLoadingOptimizationInput!): ShipmentLoadingOptimizationResponse!
  createShipmentComment(shipmentId: ID!, input: ShipmentCommentInput!): ShipmentComment!
  updateShipmentComment(shipmentId: ID!, commentId: ID!, input: ShipmentCommentUpdateInput!): ShipmentComment!
  deleteShipmentComment(shipmentId: ID!, commentId: ID!): Boolean!
}
