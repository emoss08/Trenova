enum SelectOptionResource {
  CUSTOMER
  EQUIPMENT_TYPE
  EQUIPMENT_MANUFACTURER
  TRAILER
  TRACTOR
  WORKER
  US_STATE
  SHIPMENT
  ORDER
  EDI_TRANSFER
  FUEL_INDEX
  FUEL_SURCHARGE_PROGRAM
  FISCAL_YEAR
  FISCAL_PERIOD
  GL_ACCOUNT
}

input SelectOptionsInput {
  resource: SelectOptionResource!
  query: String
  first: Int = 20
  offset: Int = 0
  ids: [ID!]
  filters: JSON
}

type SelectOption {
  id: ID!
  label: String!
  description: String
  meta: JSON
}

type SelectOptionEdge {
  node: SelectOption!
  cursor: String!
}

type SelectOptionConnection {
  edges: [SelectOptionEdge!]!
  pageInfo: PageInfo!
  totalCount: Int
}

extend type Query {
  selectOptions(input: SelectOptionsInput!): SelectOptionConnection!
}
